# Python
engine/.venv/
__pycache__/
*.pyc
.pytest_cache/

# Model weights & training output
*.pt
engine/minesight_runs/
engine/runs/

# Datasets & logs (gigabytes, regenerable via Roboflow export + the collector)
engine/datasets/
engine/*.log
engine/*.err

# Active-learning review queue (transient, machine-local)
engine/review/

# Rotating debug logs
engine/logs/

# Mod build output (mod/.gitignore also covers these)
mod/build/
mod/*/build/
mod/.gradle/
mod/.gradle-client*/
mod/*/.gradle/
mod/run/
mod/run-client*/
mod/*/run/
mod/*/run-client*/
# Safety net: dev run dirs must never escape mod/ to the repo root
/run/
/run-client*/

# IDE
.claude/
.idea/
.vscode/
*.iml
